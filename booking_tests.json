              "    pm.response.to.have.status(403);\r",
              "});\r",
              "\r",
              "pm.test(\"Тело ответа содержит ошибку Forbidden\", () => {\r",
              "\t\t// Этот сервер при 403 часто просто пишет \"Forbidden\" текстом\r",
              "    pm.expect(pm.response.text()).to.include(\"Forbidden\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
