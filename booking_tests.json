    {
      "name": "PATCH - Partial Update Booking (Частичное обновление данных)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"PATCH прошел успешно\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Поле additionalneeds обновилось\", () => {\r",
              "    pm.expect(jsonData.additionalneeds).to.eql(\"Поздний выезд\");\r",
              "});\r",
              "\r",
              "pm.test(\"Имя не изменилось после PATCH\", () => {\r",
              "    // Мы меняли только нужды, имя должно остаться Влад\r",
              "    pm.expect(jsonData.firstname).to.eql(\"Влад\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"additionalneeds\" : \"Поздний выезд\"\r\n}",
          "options": {
