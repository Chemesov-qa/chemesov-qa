    {
      "name": "PUT - Full Update Booking (Полное обновление данных)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Статус код 200 - Успешное обновление\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Данные обновлены корректно\", () => {\r",
              "    pm.expect(jsonData.firstname).to.eql(\"Влад\");\r",
              "    pm.expect(jsonData.lastname).to.eql(\"Бумага\");\r",
              "    pm.expect(jsonData.totalprice).to.eql(999);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\" : \"Влад\",\r\n    \"lastname\" : \"Бумага\",\r\n    \"totalprice\" : 999,\r\n    \"depositpaid\" : false,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2024-12-31\",\r\n        \"checkout\" : \"2025-01-01\"\r\n    },\r\n    \"additionalneeds\" : \"Побольше бумаги!\"\r\n}",
