    {
      "name": "GET Auth - Booking Details (Получение данных брони)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Статус код 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Данные в базе верны\", () => {\r",
              "    // Замени \"Ivan\" и \"Tester\" на те имена, которые ты писал в POST запросе\r",
              "    pm.expect(jsonData.firstname).to.eql(\"Денди\");\r",
              "    pm.expect(jsonData.lastname).to.eql(\"Тот Самый\");\r",
              "});\r",
              "\r",
              "pm.test(\"Формат ответа - JSON\", () => {\r",
              "    pm.response.to.be.withBody;\r",
              "    pm.response.to.be.json;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking/{{bookingid}}",
