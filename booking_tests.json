  "item": [
    {
      "name": "POST Auth - Create Token (Авторизация и получение токена)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Токен успешно получен\", () => {\r",
              "    pm.expect(jsonData).to.have.property('token');\r",
              "});\r",
              "\r",
              "if (jsonData.token) {\r",
              "    pm.environment.set(\"token\", jsonData.token);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\" : \"admin\",\r\n    \"password\" : \"password123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://restful-booker.herokuapp.com/auth",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "auth"
          ]
        },
        "description": "Отправка учетных данных админа для получения _**токена**_ доступа.\n\nТокен сохраняется в _**Environment**_."
      },
      "response": []
    },
    {
      "name": "POST Auth - Room Booking (Бронирование комнаты)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Бронирование создано\", () => {\r",
              "    pm.expect(jsonData).to.have.property('bookingid');\r",
              "});\r",
              "\r",
              "// Сохраняем ID, чтобы потом именно это бронирование УДАЛИТЬ\r",
              "pm.environment.set(\"bookingid\", jsonData.bookingid);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\" : \"Денди\",\r\n    \"lastname\" : \"Тот Самый\",\r\n    \"totalprice\" : 100,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2024-01-01\",\r\n        \"checkout\" : \"2024-01-05\"\r\n    },\r\n    \"additionalneeds\" : \"Нужен ПК\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking"
          ]
        },
        "description": "Создание _**нового**_ бронирования.\n\nСохранение уникального _**bookingid**_ для дальнейших тестов."
