    {
      "name": "GET - Filter By Lastname (Фильтрация списка по фамилии)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Статус код 200 - Поиск выполнен\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Результаты поиска - это список (массив)\", () => {\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Наша бронь (Влад Бумага) найдена в списке\", () => {\r",
              "    // Берем ID нашей брони из памяти (окружения)\r",
              "    const ourId = parseInt(pm.environment.get(\"bookingid\"));\r",
              "    \r",
              "    // Проверяем, есть ли такой ID в пришедшем списке\r",
              "    const isFound = jsonData.some(item => item.bookingid === ourId);\r",
              "    \r",
              "    pm.expect(isFound).to.be.true;\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://restful-booker.herokuapp.com/booking?lastname=Бумага",
          "protocol": "https",
          "host": [
            "restful-booker",
            "herokuapp",
            "com"
          ],
          "path": [
            "booking"
          ],
          "query": [
            {
              "key": "lastname",
              "value": "Бумага"
            }
          ]
        },
        "description": "_**Тестирование поиска**_ по Query-параметрам.\n\nПроверка _**наличия созданного ID**_ в результатах фильтрации."
      },
      "response": []
    },
